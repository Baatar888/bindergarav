# ========================================
# ЭНЭХҮҮ ФАЙЛЫГ .env.local БОЛГОН ХАДГАЛНА
# Vercel-д environment variables нэмнэ үү
# ========================================

# MongoDB Atlas холболт
# mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/emneleg?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/emneleg?retryWrites=true&w=majority

# Admin нууц үг (өөртөө тохируулах)
ADMIN_PASSWORD=your_strong_password_here

# Cloudinary - https://cloudinary.com/console дээрээс авна
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
